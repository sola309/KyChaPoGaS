# KyChaPoGaS backend configuration
# Copy this file to .env and fill in your values.
# .env is NOT committed to git.

HOST=0.0.0.0
PORT=8002

# Anthropic API key — required for LLM chat (Claude assistant)
ANTHROPIC_API_KEY=sk-ant-...

# Model for LLM chat
LLM_MODEL=claude-sonnet-4-6

# ComfyUI server URL
COMFYUI_URL=http://localhost:8188

# Civitai API token — required to download Civitai models (e.g. WAI Illustrious).
# Get one at https://civitai.com/user/account → "API Keys". Keep it secret.
CIVITAI_TOKEN=

# ACE-Step music generation service (independent local service)
ACESTEP_API_URL=http://localhost:7867

# ── 共同編集セキュリティ: 埋め込みターミナル（ホストのシェル）の許可制御 ──
# 招待者にホスト操作を渡さないため、ターミナルは接続元IP(Tailscaleが強制)で制限する。
#   ADMIN_TERMINAL_IPS … カンマ区切りの「管理者の端末のTailscale IP」。ここからのみ
#                        ターミナル可。招待者は別IPなので不可。(+ loopbackは常に可)
#   KYCHAPOGAS_DISABLE_TERMINAL=1 … 全員に対してターミナル無効（強制オフ）
# どちらも未設定なら全員可（単独利用時の既定）。詳細: docs/collaborator-invite-tailscale.md
ADMIN_TERMINAL_IPS=
KYCHAPOGAS_DISABLE_TERMINAL=

# Terminal server port (default: 8765)
TERMINAL_PORT=8765
TERMINAL_HOST=127.0.0.1
